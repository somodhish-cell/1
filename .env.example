# Copy to .env and adjust as needed.

# Server
PORT=3000
NODE_ENV=development

# Session secret — REQUIRED in production (a long random string).
SESSION_SECRET=change-me-to-a-long-random-secret

# Default admin account created on first seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Database (libSQL) -------------------------------------------------
# Leave unset for a local file DB (default: data/app.db).
# For Vercel/serverless, point at a Turso database:
#   DATABASE_URL=libsql://your-db.turso.io
#   DATABASE_AUTH_TOKEN=your-turso-token

# --- Uploads -----------------------------------------------------------
# Leave unset to store images on local disk (public/uploads).
# On serverless (Vercel) set a Blob token to store images in Vercel Blob:
#   BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
# On container hosts, point uploads at the mounted volume:
#   UPLOADS_DIR=/var/data/uploads

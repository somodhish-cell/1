<article class="product-card">
  <a class="product-thumb" href="/product/<%= product.slug %>">
    <% if (product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" />
    <% } else { %>
      <div class="thumb-placeholder">No image</div>
    <% } %>
    <% if (product.featured) { %><span class="tag tag-featured">Featured</span><% } %>
    <% if (product.stock <= 0) { %><span class="tag tag-out">Sold out</span><% } %>
  </a>
  <div class="product-body">
    <% if (product.category_name) { %><span class="product-cat"><%= product.category_name %></span><% } %>
    <h3 class="product-name"><a href="/product/<%= product.slug %>"><%= product.name %></a></h3>
    <div class="product-foot">
      <span class="price"><%= money(product.price) %></span>
      <% if (product.stock > 0) { %>
        <form action="/cart/add" method="post" class="inline-form">
          <input type="hidden" name="product_id" value="<%= product.id %>" />
          <button type="submit" class="btn btn-sm">Add</button>
        </form>
      <% } else { %>
        <span class="muted small">Out of stock</span>
      <% } %>
    </div>
  </div>
</article>

<div class="panel-head">
  <a href="/admin/orders" class="link-arrow">← All orders</a>
</div>

<div class="admin-cols">
  <div class="panel">
    <div class="panel-head">
      <h2>Order #<%= String(order.id).padStart(4, '0') %></h2>
      <span class="badge badge-<%= order.status %>"><%= order.status %></span>
    </div>

    <table class="table">
      <thead><tr><th>Item</th><th>Price</th><th>Qty</th><th>Subtotal</th></tr></thead>
      <tbody>
        <% items.forEach(function (it) { %>
          <tr>
            <td><%= it.name %></td>
            <td><%= money(it.price) %></td>
            <td><%= it.qty %></td>
            <td><%= money(it.price * it.qty) %></td>
          </tr>
        <% }); %>
      </tbody>
      <tfoot>
        <tr><td colspan="3" class="text-right"><strong>Total</strong></td><td><strong><%= money(order.total) %></strong></td></tr>
      </tfoot>
    </table>
  </div>

  <div class="panel">
    <div class="panel-head"><h2>Customer</h2></div>
    <dl class="detail-list">
      <dt>Name</dt><dd><%= order.customer_name %></dd>
      <dt>Email</dt><dd><a href="mailto:<%= order.email %>"><%= order.email %></a></dd>
      <% if (order.phone) { %><dt>Phone</dt><dd><%= order.phone %></dd><% } %>
      <% if (order.address) { %><dt>Address</dt><dd><%= order.address %></dd><% } %>
      <% if (order.notes) { %><dt>Notes</dt><dd><%= order.notes %></dd><% } %>
      <dt>Placed</dt><dd><%= formatDate(order.created_at) %></dd>
    </dl>

    <div class="panel-head" style="margin-top:1.5rem"><h2>Update status</h2></div>
    <form action="/admin/orders/<%= order.id %>/status" method="post" class="form status-form">
      <select name="status">
        <% ['pending','paid','shipped','cancelled'].forEach(function (s) { %>
          <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
        <% }); %>
      </select>
      <button type="submit" class="btn">Update</button>
    </form>
  </div>
</div>
